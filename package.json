{
    "name": "n8n-nodes-2captcha-official",
    "version": "1.0.16",
    "description": "Official n8n node to bypass captchas natively using 2Captcha API",
    "license": "MIT",
    "homepage": "https://2captcha.com",
    "keywords": [
        "n8n-community-node-package",
        "2captcha",
        "captcha",
        "solver",
        "recaptcha",
        "cloudflare"
    ],
    "author": {
        "name": "2Captcha",
        "email": "alex@2captcha.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/2captchar/n8n-nodes-2captcha.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/TwoCaptchaApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/TwoCaptcha/TwoCaptcha.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.39.4",
        "prettier": "3.8.1",
        "release-it": "19.2.4",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}